# Configuration de my'chat
# Copie ce fichier en .env et remplis tes informations

# ============================================================
# CLAUDE API (Obligatoire)
# ============================================================
ANTHROPIC_API_KEY=sk_ant_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================
# CORS — liste JSON des origines autorisées
# En local: laisser la valeur par défaut
# Sur Railway: mettre l'URL de ton app (ex: https://mychat.up.railway.app)
# ============================================================
ALLOWED_ORIGINS=["http://localhost:8000","http://localhost:3000"]

# ============================================================
# SERVEUR (Railway injecte PORT automatiquement)
# ============================================================
PORT=8000
